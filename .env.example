# Deficit — environment variables.
# Copy this file to `.env` and fill in the values, then restart `expo start`.
# Anything prefixed EXPO_PUBLIC_ is embedded in the client bundle (safe for the
# Supabase URL + anon key — the anon key is meant to be public; row-level
# security is what protects data).

# From Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- NOT used by the app; set these as Edge Function SECRETS instead ---
# supabase secrets set GEMINI_API_KEY=... FATSECRET_CLIENT_ID=... FATSECRET_CLIENT_SECRET=...
# (listed here only as a reminder of what the `food` function needs)
#   GEMINI_API_KEY=            # Google AI Studio
#   FATSECRET_CLIENT_ID=       # FatSecret Platform app
#   FATSECRET_CLIENT_SECRET=
